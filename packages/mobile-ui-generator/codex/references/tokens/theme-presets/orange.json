  "gradients": {
    "headerBg": "linear-gradient(135deg, #F97316 0%, #FB923C 50%, #FDBA74 100%)",
    "cardAccent": "linear-gradient(135deg, #F97316 0%, #F59E0B 100%)",
    "tabbarActive": "linear-gradient(135deg, #F97316 0%, #FB923C 100%)"
  }
